# Copy to .env and fill in. Foundry loads .env from repo root.

# Required for deploy (forge script --broadcast)
PRIVATE_KEY=0x...

# Optional: Base RPC for fork tests (default: https://mainnet.base.org)
BASE_RPC_URL=https://mainnet.base.org

# Optional: for --verify on Base
# BASESCAN_API_KEY=...

# ========================================
# MorphoFlashloanCallbackModule Config
# ========================================

# Safe smart account address (deployed via Rhinestone)
# SAFE_ACCOUNT_ADDRESS=0x...

# Deployed MorphoFlashloanCallbackModule address
# MORPHO_FLASHLOAN_MODULE_ADDRESS=0x...

# Pimlico API key for bundler/paymaster
# PIMLICO_API_KEY=...
